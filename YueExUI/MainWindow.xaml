<Window x:Class="YueExUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YueEx Dashboard" Height="450" Width="800" Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnInject" Content="Inject YueEx.dll" Width="120" Height="30" Margin="0,0,10,0" Click="BtnInject_Click" Background="#333333" Foreground="White" BorderBrush="#555555"/>
            <TextBlock x:Name="TxtStatus" Text="Status: Not Injected" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Luau Script" Grid.Column="0" Foreground="White" BorderBrush="#555555">
                <TextBox x:Name="TxtScript" AcceptsReturn="True" Background="#252526" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="14" BorderThickness="0" Margin="5">
                    print("Hello from YueEx!")
                </TextBox>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#1E1E1E"/>

            <GroupBox Header="Output Console" Grid.Column="2" Foreground="White" BorderBrush="#555555">
                <TextBox x:Name="TxtOutput" IsReadOnly="True" AcceptsReturn="True" Background="#252526" Foreground="#4EC9B0" FontFamily="Consolas" FontSize="14" BorderThickness="0" Margin="5"/>
            </GroupBox>
        </Grid>

        <Button x:Name="BtnExecute" Grid.Row="2" Content="Execute Script" Height="40" Margin="0,10,0,0" Click="BtnExecute_Click" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0"/>
    </Grid>
</Window>
